{
  "manifest_version": 3,
  "name": "ttpull",
  "version": "1.0.0",
  "description": "Bridge TikTok session to ttpull container for scheduled likes/bookmarks download",
  "permissions": [
    "cookies",
    "storage",
    "alarms",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.tiktok.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://192.168.1.3/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.tiktok.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ttpull"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
